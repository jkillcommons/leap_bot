# ── Telegram ──────────────────────────────────────────────────────────────────
LEAP_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Alpaca (paper trading) ────────────────────────────────────────────────────
# Get keys at https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=your_alpaca_paper_key_here
ALPACA_API_SECRET=your_alpaca_paper_secret_here

# ── Tradier (sandbox) ─────────────────────────────────────────────────────────
# Get a free sandbox token at https://developer.tradier.com
TRADIER_API_TOKEN=your_tradier_sandbox_token_here
# Find your account ID at https://developer.tradier.com/user/profile
TRADIER_ACCOUNT_ID=your_tradier_account_id_here
# Set to "true" only when you want live Tradier data (NOT recommended yet)
TRADIER_PRODUCTION=false

# ── Broker routing ────────────────────────────────────────────────────────────
# BROKER_MODE values:
#   paper    — AlpacaBroker paper mode, no real API calls (default)
#   sandbox  — Tradier sandbox, place real sandbox orders (requires TRADIER_*)
#   dual     — Tradier data + Alpaca paper execution (requires both sets of keys)
#
# PAPER_TRADING must stay "true" until you are deliberately going live.
DATA_BROKER=alpaca
EXEC_BROKER=alpaca
BROKER_MODE=paper
PAPER_TRADING=true
