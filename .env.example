# ── Telegram ──────────────────────────────────────────────────────────────────
LEAP_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Tradier (sandbox) ─────────────────────────────────────────────────────────
# Get a free sandbox token at https://developer.tradier.com
TRADIER_API_TOKEN=your_tradier_sandbox_token_here
# Find your account ID at https://developer.tradier.com/user/profile
TRADIER_ACCOUNT_ID=your_tradier_account_id_here
# Set to "true" only when you want the live Tradier API (NOT recommended yet)
TRADIER_PRODUCTION=false
# Explicit mode flag (sandbox = default)
TRADIER_MODE=sandbox

# ── Broker routing ────────────────────────────────────────────────────────────
# All modes use TradierClient.  BROKER_MODE controls sandbox vs future live.
# BROKER_MODE values: sandbox (default) | tradier | paper | single | dual
# PAPER_TRADING must stay "true" until you are deliberately going live.
DATA_BROKER=tradier
EXEC_BROKER=tradier
BROKER_MODE=sandbox
PAPER_TRADING=true
